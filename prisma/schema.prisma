generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  image         String?
  role          UserRole  @default(STUDENT)
  xp            Int       @default(0)
  streak        Int       @default(0)
  lastActive    DateTime  @default(now())
  
  enrollments   Enrollment[]
  userProgress  UserProgress[]
  certificates  Certificate[]
}

model KDegree {
  id          String   @id @default(cuid())
  title       String
  description String
  imagePath   String?
  courses     Course[]
  createdAt   DateTime @default(now())
}

model Course {
  id          String    @id @default(cuid())
  kDegreeId   String
  title       String
  description String
  kDegree     KDegree   @relation(fields: [kDegreeId], references: [id])
  modules     Module[]
  enrollments Enrollment[]
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  order     Int
  course    Course   @relation(fields: [courseId], references: [id])
  lessons   Lesson[]
}

model Lesson {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  videoUrl    String?
  content     String?
  isFree      Boolean  @default(false)
  order       Int
  module      Module   @relation(fields: [moduleId], references: [id])
  userProgress UserProgress[]
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  isCompleted Boolean @default(false)
  user      User     @relation(fields: [userId], references: [id])
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  
  @@unique([userId, lessonId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
}

model Certificate {
  id          String   @id @default(cuid())
  userId      String
  courseName  String
  issuedAt    DateTime @default(now())
  certificateUrl String
  user        User     @relation(fields: [userId], references: [id])
}
